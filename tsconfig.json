{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "dom"],
    "module": "node16",
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "emitDeclarationOnly": true,
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
    "paths": {
      "@y/prosemirror": ["./src/index.js"]
    }
  },
  "files": ["./global.d.ts"],
  "include": ["./src/**/*.js", "./tests/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
